rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

      // Match your specific path structure
    match /artifacts/{appId}/public/data/tournaments/{tournamentId} {

      // 1. Anyone can read
      allow read: if true;

      // 2. Anyone can create a NEW tournament
      allow create: if true;

      // 3. Update Rule:
      // You can only update if the 'password' field in your incoming data
      // matches the 'password' field currently in the database.
      // (Also allows updates if the doc has no password, for backward compatibility)
      allow update: if
          (request.resource.data.password == resource.data.password) ||
            !('password' in resource.data);
    }
  }
}