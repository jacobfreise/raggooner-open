rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Reads the current user's role from userRoles once per request evaluation.
    // Firestore caches get() calls on the same path, so all helpers below share one read.
    function getUserRole() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/artifacts/default-app/public/data/userRoles/$(request.auth.uid))
        ? get(/databases/$(database)/documents/artifacts/default-app/public/data/userRoles/$(request.auth.uid)).data.role
        : null;
    }

    function isDiscordUser() {
        return request.auth != null &&
            request.auth.token.firebase.sign_in_provider == 'oidc.discord.com';
            // Note: 'oidc.discord' is the standard provider ID for Firebase + Discord
    }

    function isSuperAdmin() {
      return getUserRole() == 'superadmin';
    }

    // True for both 'admin' and 'superadmin'
    function isAdmin() {
      return getUserRole() in ['admin', 'superadmin'];
    }

    function isOfficialCreator() {
      return getUserRole() in ['superadmin', 'admin', 'tournament_creator'];
    }

    match /artifacts/{appId}/public/data {

      // 1. PLAYERS
      match /players/{playerId} {
        // Anyone can read a single player doc by ID (e.g. avatar lookups).
        // Listing the collection requires Discord login to prevent scraping.
        allow get: if true;
        allow list: if isDiscordUser();
        allow create: if isDiscordUser();
        // Admins can update any player (needed for role sync in setUserRole).
        // Own doc update or linking an unlinked player to yourself also allowed.
        allow update: if isAdmin() ||
          (request.auth != null && resource.data.firebaseUid == request.auth.uid) ||
          (request.auth != null && !('firebaseUid' in resource.data) && request.resource.data.firebaseUid == request.auth.uid);
        allow delete: if isSuperAdmin();
      }

      // 2. SEASONS
      match /seasons/{seasonId} {
        allow get: if true;
        allow list: if isDiscordUser();
        allow write: if isSuperAdmin() || request.auth != null;
      }

      // 3. TOURNAMENTS
      match /tournaments/{tournamentId} {
        // Anyone can fetch a single tournament by ID (direct link access).
        // Listing the collection requires Discord login to prevent scraping.
        allow get: if true;
        allow list: if isDiscordUser();
        allow create: if isDiscordUser() &&
          (!('isOfficial' in request.resource.data) || !request.resource.data.isOfficial || isOfficialCreator());
        allow update, delete: if isSuperAdmin() ||
          (isDiscordUser() && exists(/databases/$(database)/documents/artifacts/$(appId)/public/data/admins/$(tournamentId + '_' + request.auth.uid)));
      }

      // 4. SECRETS
      match /secrets/{tournamentId} {
        allow create: if isDiscordUser();
        allow read, update, delete: if request.auth != null &&
          exists(/databases/$(database)/documents/artifacts/$(appId)/public/data/admins/$(tournamentId + '_' + request.auth.uid));
      }

      // 5. ADMINS
      match /admins/{adminDoc} {
        // Admins and superadmins can manage all admin slips (needed for tournament password bypass).
        allow read, create, update, delete: if isAdmin();

        // Users can read and delete their own admin slip
        allow get: if isDiscordUser() && resource.data.userId == request.auth.uid;
        allow delete: if isDiscordUser() && resource.data.userId == request.auth.uid;

        // Regular users can create a slip by providing the correct tournament password
        allow create: if isDiscordUser() &&
          request.resource.data.password == getAfter(/databases/$(database)/documents/artifacts/$(appId)/public/data/secrets/$(request.resource.data.tournamentId)).data.password;
      }

      // 6. GLOBAL SETTINGS
      match /settings/{docId} {
        allow get: if true;
        allow list: if isDiscordUser();
        allow write: if isOfficialCreator();
      }

      // 8. USAGE (analytics tracking)
      match /usage/{userId} {
        allow read: if isSuperAdmin() || (request.auth != null && userId == 'analyticsMetadata');
        allow create, update: if request.auth != null && request.auth.uid == userId;
      }

      // 9. USER ROLES
      match /userRoles/{uid} {
        // get: own doc, or any admin
        allow get: if isDiscordUser() && (request.auth.uid == uid || isAdmin());
        // list (getDocs on the collection): admins only
        allow list: if isAdmin();
        // create/update: superadmins can set any role; admins can set any role except superadmin
        allow create, update: if isSuperAdmin() ||
          (isAdmin() && request.resource.data.role != 'superadmin');
        // delete (demoting to player removes the doc): admins can delete non-superadmin role docs
        allow delete: if isSuperAdmin() ||
          (isAdmin() && resource.data.role != 'superadmin');
      }
    }
  }
}
