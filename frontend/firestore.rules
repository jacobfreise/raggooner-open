rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSuperAdmin() {
      return request.auth != null && request.auth.uid in [
        'DEINE_UID'
      ] || true;
    }

    match /artifacts/{appId}/public/data {

      // Players - Read: Everyone, Write: Authenticated
      match /players/{playerId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
        allow update: if isSuperAdmin();  // Only super admin can edit
        allow delete: if isSuperAdmin();
      }

      // Seasons
      match /seasons/{seasonId} {
        allow read: if request.auth != null;
        allow write: if isSuperAdmin() || request.auth != null;  // Only admin can manage seasons
      }

      // Tournaments (wie bisher)
      match /tournaments/{tournamentId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
        allow update, delete: if exists(/databases/$(database)/documents/artifacts/$(appId)/public/data/admins/$(tournamentId + '_' + request.auth.uid));
      }

      // Participations - Written by tournament logic
      match /participations/{participationId} {
        allow read: if request.auth != null;
        allow write: if isSuperAdmin() ||
          exists(/databases/$(database)/documents/artifacts/$(appId)/public/data/admins/$(resource.data.tournamentId + '_' + request.auth.uid));
      }

      // Races - Same as participations
      match /races/{raceId} {
        allow read: if request.auth != null;
        allow write: if isSuperAdmin() ||
          exists(/databases/$(database)/documents/artifacts/$(appId)/public/data/admins/$(resource.data.tournamentId + '_' + request.auth.uid));
      }

      // Admins (wie bisher)
      match /admins/{adminDoc} {
        allow read, write: if isSuperAdmin();
        allow create: if request.auth != null &&
          request.resource.data.password == get(/databases/$(database)/documents/artifacts/$(appId)/public/data/tournaments/$(request.resource.data.tournamentId)).data.password;
        allow read: if request.auth != null &&
          request.resource.data.userId == request.auth.uid;
      }
    }
  }
}