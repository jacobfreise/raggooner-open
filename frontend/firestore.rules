rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSuperAdmin() {
      return request.auth != null && (request.auth.uid in [
      'mehTFP5BuqdrT6mw4xqnaNrHSMk1', 'j7kIBg1mIXO5m824GeBQmXYfb6q2', 'LCwXSR9TZUPqdpv8qM7qD3y7m0uh', 'JXs2aov8XqTfnB9XLOVHVNzw3psv',
      'JrBubSUpmlNqYV4Gi7TsYY7yRqzO', '0u3zMN1xD3SrcVKIzw10UMvnmFJ2'
      ]);
    }

    function isOfficialCreator() {
      return isSuperAdmin() ||
        (request.auth != null &&
         exists(/databases/$(database)/documents/artifacts/default-app/public/data/userRoles/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/artifacts/default-app/public/data/userRoles/$(request.auth.uid)).data.role == 'tournament_creator');
    }

    match /artifacts/{appId}/public/data {

      // 1. PLAYERS
      match /players/{playerId} {
        allow read, create: if request.auth != null;
        // Own doc update (linked player) or linking an unlinked player to yourself
        allow update: if isSuperAdmin() ||
          (request.auth != null && resource.data.firebaseUid == request.auth.uid) ||
          (request.auth != null && !('firebaseUid' in resource.data) && request.resource.data.firebaseUid == request.auth.uid);
        allow delete: if isSuperAdmin();
      }

      // 2. SEASONS
      match /seasons/{seasonId} {
        allow read: if request.auth != null;
        allow write: if isSuperAdmin() || request.auth != null;
      }

      // 3. TOURNAMENTS
      match /tournaments/{tournamentId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null &&
          (!('isOfficial' in request.resource.data) || !request.resource.data.isOfficial || isOfficialCreator());
        // FIX: Added request.auth != null to prevent evaluation crashes
        allow update, delete: if isSuperAdmin() || request.auth != null &&
          exists(/databases/$(database)/documents/artifacts/$(appId)/public/data/admins/$(tournamentId + '_' + request.auth.uid));
      }

      // 7. USER ROLES
      match /userRoles/{uid} {
        allow read: if request.auth != null && (request.auth.uid == uid || isSuperAdmin());
        allow write: if isSuperAdmin();
      }

      // 4. SECRETS
      match /secrets/{tournamentId} {
        // Anyone can create a secret (used during batch tournament creation)
        allow create: if request.auth != null;
        // Only verified admins of this tournament can read or change the password
        allow read, update, delete: if request.auth != null &&
          exists(/databases/$(database)/documents/artifacts/$(appId)/public/data/admins/$(tournamentId + '_' + request.auth.uid));
      }

      // 5. ADMINS
      match /admins/{adminDoc} {
        allow read, create, update, delete: if isSuperAdmin();

        // Users can read their own admin slip
        allow get: if request.auth != null && resource.data.userId == request.auth.uid;

        // Users can delete their own admin slip (tournament cleanup)
        allow delete: if request.auth != null && resource.data.userId == request.auth.uid;

        // FIX: Check the password against the SECRETS collection using getAfter()
        // getAfter() allows Firestore to look at the data being written in the current batch
        allow create: if request.auth != null &&
          request.resource.data.password == getAfter(/databases/$(database)/documents/artifacts/$(appId)/public/data/secrets/$(request.resource.data.tournamentId)).data.password;
      }

      // 6. USAGE (analytics tracking)
      match /usage/{userId} {
        // analyticsMetadata: any auth user can read, only superadmin writes (via script)
        allow read: if isSuperAdmin() || (request.auth != null && userId == 'analyticsMetadata');
        allow create, update: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}